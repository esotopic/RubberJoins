@page
@model IndexModel

@{
    ViewData["Title"] = "Today";
}

<div class="page-content">
    <header class="page-header">
        <div class="logo">RUBBERJOINTS</div>
        <div class="badge">Week @Model.ViewModel.Week of 12 · Phase @Model.ViewModel.Phase: @GetPhaseLabel(Model.ViewModel.Phase)</div>
    </header>

    @if (!string.IsNullOrEmpty(Model.ViewModel.ErrorMessage))
    {
        <div class="error-banner">@Model.ViewModel.ErrorMessage</div>
    }

    <section class="hero-section">
        <h1 class="hero-day">@Model.ViewModel.DayName</h1>
        <p class="hero-type">@Model.ViewModel.SessionType</p>
        <p class="hero-time">~@Model.ViewModel.EstMinutes mins</p>
        <p class="hero-location">@GetLocationEmoji(Model.ViewModel.DayKey) @GetLocationName(Model.ViewModel.DayKey)</p>
    </section>

    <section class="legend-section">
        <div class="legend-item">
            <span class="legend-dot" style="background-color: #45c4a0;"></span>
            <span>Mobility</span>
        </div>
        <div class="legend-item">
            <span class="legend-dot" style="background-color: #9b59b6;"></span>
            <span>Strength</span>
        </div>
        <div class="legend-item">
            <span class="legend-dot" style="background-color: #ff6b35;"></span>
            <span>Warm-up</span>
        </div>
        <div class="legend-item">
            <span class="legend-dot" style="background-color: #4a90e2;"></span>
            <span>Recovery</span>
        </div>
    </section>

    @if (Model.ViewModel.Steps.Any())
    {
        @{
            var grouped = Model.ViewModel.Steps
                .GroupBy(s => s.Exercise.Category)
                .OrderBy(g => GetSectionOrder(g.Key));
        }

        @foreach (var group in grouped)
        {
            <div class="session-group">
                <div class="session-group-header">
                    <span class="dot" style="background-color: @GetCategoryColor(group.Key);"></span>
                    <span>@GetSectionLabel(group.Key)</span>
                </div>
                @foreach (var step in group)
                {
                    <div class="check-item @(step.Checked ? "done" : "")" data-step-id="@step.Index">
                        <div class="check-box" data-step-id="@step.Index" data-exercise-id="@step.Exercise.Id"></div>
                        <div class="check-info">
                            <span class="check-name">@step.Exercise.Name</span>
                            <span class="check-sub">@step.Exercise.Targets</span>
                        </div>
                        <span class="check-reps">@step.Rx</span>
                    </div>
                    <div class="detail" data-detail-for="@step.Index">
                        <p>@step.Exercise.Description</p>
                        @if (!string.IsNullOrEmpty(step.Exercise.Cues))
                        {
                            <ul>
                                @foreach (var cue in step.Exercise.Cues.Split('|'))
                                {
                                    <li>@cue.Trim()</li>
                                }
                            </ul>
                        }
                        @if (!string.IsNullOrEmpty(step.Exercise.Warning))
                        {
                            <p class="detail-warning">@step.Exercise.Warning</p>
                        }
                    </div>
                }
            </div>
        }
    }
    else if (Model.ViewModel.DayKey == "rest")
    {
        <div class="card" style="margin-top:16px;text-align:center;">
            <p style="color:var(--tx2);padding:24px 0;">Today is a rest day. Take it easy and recover!</p>
        </div>
    }

    @if (Model.ViewModel.Supplements.Any())
    {
        <section class="supplements-card">
            <h2 class="card-title">Supplements</h2>
            <div class="supplements-list">
                @foreach (var group in Model.ViewModel.Supplements.GroupBy(s => s.Supplement.TimeGroup))
                {
                    <div class="supplement-group">
                        <h3 class="group-title">@GetTimeGroupLabel(group.Key)</h3>
                        @foreach (var item in group)
                        {
                            <div class="supplement-item">
                                <input type="checkbox" class="supplement-checkbox"
                                       data-supplement-id="@item.Supplement.Id"
                                       @(item.Checked ? "checked" : "")>
                                <span class="supplement-name">@item.Supplement.Name</span>
                                <span class="supplement-dose">@item.Supplement.Dose</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
    }

    <div style="height: 100px;"></div>
</div>

<script>
// Session step checkboxes
document.querySelectorAll('.check-box[data-step-id]').forEach(box => {
    box.addEventListener('click', async (e) => {
        const item = box.closest('.check-item');
        const stepId = box.dataset.stepId;
        const exerciseId = box.dataset.exerciseId;
        const wasDone = item.classList.contains('done');

        item.classList.toggle('done');

        try {
            const response = await fetch('/Api?handler=check', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    itemType: 'step',
                    itemId: stepId,
                    exerciseId: exerciseId,
                    stepIndex: stepId
                })
            });
            if (!response.ok) {
                item.classList.toggle('done');
            }
        } catch (error) {
            item.classList.toggle('done');
            console.error('Error:', error);
        }
    });
});

// Supplement checkboxes
document.querySelectorAll('.supplement-checkbox').forEach(checkbox => {
    checkbox.addEventListener('change', async (e) => {
        const supplementId = e.target.dataset.supplementId;
        try {
            const response = await fetch('/Api?handler=check', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    itemType: 'supplement',
                    itemId: supplementId,
                    stepIndex: 0
                })
            });
            if (!response.ok) {
                e.target.checked = !e.target.checked;
            }
        } catch (error) {
            e.target.checked = !e.target.checked;
            console.error('Error:', error);
        }
    });
});

// Tap exercise name to expand detail
document.querySelectorAll('.check-info').forEach(info => {
    info.addEventListener('click', (e) => {
        const item = info.closest('.check-item');
        const stepId = item.dataset.stepId;
        const detail = document.querySelector(`.detail[data-detail-for="${stepId}"]`);
        if (detail) {
            detail.classList.toggle('open');
        }
    });
});
</script>

@functions {
    private string GetPhaseLabel(int phase)
    {
        return phase switch
        {
            1 => "Foundation",
            2 => "Strength",
            _ => "Unknown"
        };
    }

    private string GetLocationEmoji(string dayKey)
    {
        return dayKey switch
        {
            "gym" => "🏋️",
            "home" => "🏠",
            "recovery" => "🏠",
            "rest" => "🛏️",
            _ => "📍"
        };
    }

    private string GetLocationName(string dayKey)
    {
        return dayKey switch
        {
            "gym" => "Gym",
            "home" => "Home",
            "recovery" => "Home",
            "rest" => "Rest",
            _ => "Unknown"
        };
    }

    private string GetCategoryColor(string category)
    {
        return category switch
        {
            "mobility" => "#45c4a0",
            "strength" => "#9b59b6",
            "warmup_tool" => "#ff6b35",
            "recovery_tool" => "#4a90e2",
            _ => "#7b9aff"
        };
    }

    private int GetSectionOrder(string category)
    {
        return category switch
        {
            "warmup_tool" => 0,
            "mobility" => 1,
            "strength" => 2,
            "recovery_tool" => 3,
            _ => 4
        };
    }

    private string GetSectionLabel(string category)
    {
        return category switch
        {
            "warmup_tool" => "Warm-up",
            "mobility" => "Mobility",
            "strength" => "Strength",
            "recovery_tool" => "Recovery",
            _ => "Other"
        };
    }

    private string GetTimeGroupLabel(string timeGroup)
    {
        return timeGroup switch
        {
            "am" => "Morning",
            "mid" => "Midday",
            "pm" => "Evening",
            _ => "Unknown"
        };
    }
}
